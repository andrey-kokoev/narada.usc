{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/task-graph.schema.json",
  "title": "USC Task Graph",
  "type": "object",
  "required": ["tasks", "edges"],
  "properties": {
    "$schema": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": { "$ref": "./task.schema.json" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": { "enum": ["blocks", "validates", "conflicts_with", "supersedes", "derives"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
