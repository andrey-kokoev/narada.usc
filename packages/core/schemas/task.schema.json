{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/task.schema.json",
  "title": "USC Task",
  "type": "object",
  "required": ["id", "title", "authority_locus", "transformation", "evidence_requirement", "review_predicate", "status", "inputs", "expected_outputs", "acceptance"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "intent": { "type": "string" },
    "scope": { "type": "string" },
    "authority_locus": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "depends_on": { "type": "array", "items": { "type": "string" }, "description": "Task IDs that must be admitted before this task is runnable." },
    "transformation": { "type": "string" },
    "output_artifact": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "evidence_requirement": { "type": "string" },
    "review_predicate": { "type": "string" },
    "residual_handling": { "type": "string" },
    "status": {
      "enum": ["draft", "proposed", "admitted", "archived"]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "format": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["criteria"],
      "properties": {
        "criteria": { "type": "array", "items": { "type": "string" } },
        "automation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to admissibility policies that govern this task."
    },
    "policy_obligations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific policy obligations this task must satisfy."
    }
  },
  "additionalProperties": false
}
