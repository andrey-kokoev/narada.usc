{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/task.schema.json",
  "title": "USC Task",
  "type": "object",
  "required": ["id", "title", "authority_locus", "transformation", "evidence_requirement", "review_predicate", "status", "inputs", "expected_outputs", "acceptance"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "intent": { "type": "string" },
    "scope": { "type": "string" },
    "authority_locus": { "type": "string" },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "depends_on": { "type": "array", "items": { "type": "string" }, "description": "Task IDs that must be completed before this task is runnable." },
    "transformation": { "type": "string" },
    "output_artifact": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "evidence_requirement": { "type": "string" },
    "review_predicate": { "type": "string" },
    "residual_handling": { "type": "string" },
    "status": {
      "enum": ["pending", "claimed", "completed", "rejected", "blocked"]
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "source": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "format": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "acceptance": {
      "type": "object",
      "required": ["criteria"],
      "properties": {
        "criteria": { "type": "array", "items": { "type": "string" } },
        "automation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "required": ["claimant", "claimed_at"],
      "properties": {
        "claimant": { "type": "string" },
        "claimed_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "required": ["reviewer", "outcome", "reviewed_at"],
      "properties": {
        "reviewer": { "type": "string" },
        "outcome": { "enum": ["accept", "reject", "residualize", "reopen"] },
        "reason": { "type": "string" },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "next_action": { "type": "string" }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": ["artifact_reference", "completed_at", "completed_by", "reviewed_by"],
      "properties": {
        "artifact_reference": { "type": "string" },
        "completed_at": { "type": "string", "format": "date-time" },
        "completed_by": { "type": "string" },
        "reviewed_by": { "type": "string" }
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "required": ["reason"],
      "properties": {
        "reason": { "type": "string" },
        "unblock_condition": { "type": "string" }
      },
      "additionalProperties": false
    },
    "policy_refs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "References to admissibility policies that govern this task."
    },
    "policy_obligations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Specific policy obligations this task must satisfy."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "claimed" } } },
      "then": { "required": ["claim"] }
    },
    {
      "if": { "properties": { "status": { "const": "completed" } } },
      "then": { "required": ["result"] }
    },
    {
      "if": { "properties": { "status": { "const": "rejected" } } },
      "then": { "required": ["review"] }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } } },
      "then": { "required": ["block"] }
    }
  ],
  "additionalProperties": false
}
