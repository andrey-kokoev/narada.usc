{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/learning-management-context.schema.json",
  "title": "Learning Management Domain Context",
  "type": "object",
  "required": ["domain", "roles", "enrollment_model", "content_formats"],
  "properties": {
    "domain": { "const": "learning-management" },
    "roles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Supported roles (learner, instructor, admin, etc.)"
    },
    "enrollment_model": {
      "type": "string",
      "enum": ["self-enroll", "admin-assign", "cohort-based", "invitation-only"],
      "description": "How learners are enrolled"
    },
    "content_formats": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Content formats supported in MVP"
    },
    "assessments": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Assessment types supported"
    },
    "certificates": {
      "type": "boolean",
      "description": "Whether certificates are required"
    },
    "payment_model": {
      "type": "string",
      "enum": ["free", "paid", "subscription", "reimbursement"],
      "description": "Payment or training cost model"
    },
    "notifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Notification types"
    },
    "reporting": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reporting and analytics features"
    },
    "compliance": {
      "type": "boolean",
      "description": "Whether compliance/regulatory training is required"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External system integrations"
    }
  },
  "additionalProperties": false
}
