{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/real-estate-context.schema.json",
  "title": "Real Estate Domain Context",
  "type": "object",
  "properties": {
    "focus": {
      "type": "string",
      "enum": ["residential", "commercial", "mixed"]
    },
    "business_model": {
      "type": "string",
      "enum": ["sales", "rentals", "property-management", "mixed"]
    },
    "roles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "lease_in_scope": {
      "type": "boolean"
    },
    "payments_in_scope": {
      "type": "boolean"
    },
    "maintenance_tracking": {
      "type": "boolean"
    },
    "payment_methods": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mls_integration": {
      "type": "boolean"
    },
    "jurisdiction": {
      "type": "string"
    }
  }
}
