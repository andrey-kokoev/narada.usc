{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/project-management-context.schema.json",
  "title": "Project Management Domain Context",
  "type": "object",
  "properties": {
    "planning_model": {
      "type": "string",
      "enum": ["sprint", "kanban", "milestone", "waterfall", "hybrid"]
    },
    "entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assignment_model": {
      "type": "string",
      "enum": ["individual", "team", "role", "auto-assigned"]
    },
    "done_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "estimate_model": {
      "type": "string",
      "enum": ["time", "points", "t-shirt", "none"]
    },
    "permission_model": {
      "type": "string",
      "enum": ["open", "project-private", "org-private", "role-based"]
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reporting_required": {
      "type": "boolean"
    }
  }
}
