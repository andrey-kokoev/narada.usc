{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/healthcare-ops-context.schema.json",
  "title": "Healthcare Operations Domain Context",
  "type": "object",
  "properties": {
    "primary_user": {
      "type": "string",
      "enum": ["patient", "provider", "staff", "administrator"]
    },
    "workflows": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Care workflows in scope"
    },
    "scheduling_model": {
      "type": "string",
      "enum": ["patient-self-service", "staff-only", "walk-in", "mixed"]
    },
    "compliance_framework": {
      "type": "string",
      "enum": ["HIPAA", "state", "institutional", "none"]
    },
    "clinical_boundary": {
      "type": "string",
      "description": "Explicit boundary of clinical vs administrative scope"
    },
    "ehr_integration": {
      "type": "boolean"
    },
    "billing_in_scope": {
      "type": "boolean"
    }
  }
}
