{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/notifications-messaging-context.schema.json",
  "title": "Notifications and Messaging Domain Context",
  "type": "object",
  "properties": {
    "channels": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required communication channels"
    },
    "message_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Message categories in scope"
    },
    "delivery_guarantee": {
      "type": "string",
      "enum": ["at-most-once", "at-least-once", "exactly-once"]
    },
    "consent_model": {
      "type": "string",
      "enum": ["explicit-opt-in", "implicit", "granular-per-channel"]
    },
    "scheduling": {
      "type": "string",
      "enum": ["immediate-only", "scheduled", "rate-limited"]
    },
    "compliance_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tracking_required": {
      "type": "boolean"
    },
    "providers": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
