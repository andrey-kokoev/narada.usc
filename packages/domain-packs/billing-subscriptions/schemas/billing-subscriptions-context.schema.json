{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/billing-subscriptions-context.schema.json",
  "title": "Billing & Subscriptions Domain Pack Context",
  "description": "Context parameters for the billing and subscriptions domain pack refinement",
  "type": "object",
  "properties": {
    "pricing_model": {
      "type": "string",
      "enum": ["flat", "tiered", "usage-based", "per-seat", "hybrid"]
    },
    "plan_structure": {
      "type": "string"
    },
    "subscription_lifecycle": {
      "type": "array",
      "items": { "type": "string" }
    },
    "trials_promotions": {
      "type": "boolean"
    },
    "usage_metering": {
      "type": "boolean"
    },
    "tax_obligations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "payment_methods": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dunning_policy": {
      "type": "string"
    },
    "refund_authority": {
      "type": "string"
    },
    "revenue_recognition": {
      "type": "boolean"
    }
  }
}
