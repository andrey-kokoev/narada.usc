{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/crm-context.schema.json",
  "title": "CRM Domain Context",
  "type": "object",
  "required": ["domain", "purpose", "entities"],
  "properties": {
    "domain": { "const": "crm" },
    "purpose": {
      "type": "array",
      "items": { "type": "string", "enum": ["sales", "support", "success", "marketing", "combined"] },
      "description": "CRM purpose and scope"
    },
    "entities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tracked entities (leads, contacts, accounts, deals, tickets)"
    },
    "pipeline_stages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pipeline or lifecycle stages"
    },
    "activities": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tracked activity types"
    },
    "assignment_model": {
      "type": "string",
      "enum": ["manual", "round-robin", "territory", "skill-based"],
      "description": "How records are assigned"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External system integrations"
    },
    "reporting": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Reporting and forecasting features"
    }
  },
  "additionalProperties": false
}
