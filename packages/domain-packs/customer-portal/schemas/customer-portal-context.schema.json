{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/customer-portal-context.schema.json",
  "title": "Customer Portal Domain Pack Context",
  "description": "Context parameters for the customer portal domain pack refinement",
  "type": "object",
  "properties": {
    "auth_model": {
      "type": "string",
      "enum": ["password", "sso", "magic-link", "social", "mfa"]
    },
    "profile_management": {
      "type": "array",
      "items": { "type": "string" }
    },
    "documents_files": {
      "type": "boolean"
    },
    "support_requests": {
      "type": "boolean"
    },
    "billing_visibility": {
      "type": "boolean"
    },
    "notifications": {
      "type": "array",
      "items": { "type": "string" }
    },
    "delegated_users": {
      "type": "boolean"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "branding_localization": {
      "type": "boolean"
    },
    "mvp_boundary": {
      "type": "string"
    }
  }
}
