{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/booking-context.schema.json",
  "title": "Booking Domain Context",
  "type": "object",
  "required": ["domain", "resources", "booking_actor"],
  "properties": {
    "domain": { "const": "booking" },
    "resources": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bookable resource types"
    },
    "booking_actor": {
      "type": "string",
      "enum": ["self", "admin", "member", "referral", "invitation"],
      "description": "Who can make bookings"
    },
    "workflow": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Booking workflow stages"
    },
    "availability_model": {
      "type": "string",
      "enum": ["fixed-slots", "flexible", "recurring", "calendar"],
      "description": "How availability is defined"
    },
    "payment_model": {
      "type": "string",
      "enum": ["free", "deposit", "full", "invoice", "at-time", "none"],
      "description": "Payment model if any"
    },
    "cancellation_policy": {
      "type": "string",
      "enum": ["strict", "moderate", "flexible", "custom"],
      "description": "Cancellation policy type"
    },
    "waitlist": {
      "type": "boolean",
      "description": "Whether waitlist is supported"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External system integrations"
    }
  },
  "additionalProperties": false
}
