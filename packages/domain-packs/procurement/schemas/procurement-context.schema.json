{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/procurement-context.schema.json",
  "title": "Procurement Domain Context",
  "type": "object",
  "required": ["domain", "requisition_workflow", "approval_rules", "po_required"],
  "properties": {
    "domain": { "const": "procurement" },
    "requisition_workflow": {
      "type": "string",
      "enum": ["catalog", "free-form", "hybrid"],
      "description": "How requisitions are created"
    },
    "approval_rules": {
      "type": "object",
      "properties": {
        "thresholds": { "type": "array", "items": { "type": "number" } },
        "dual_approval": { "type": "boolean" },
        "role_based": { "type": "boolean" }
      }
    },
    "po_required": {
      "type": "boolean",
      "description": "Whether purchase orders are required"
    },
    "po_generation": {
      "type": "string",
      "enum": ["manual", "generated", "erp-integrated"],
      "description": "How POs are generated"
    },
    "matching_model": {
      "type": "string",
      "enum": ["two-way", "three-way", "none"],
      "description": "Receiving and matching model"
    },
    "budgets": {
      "type": "boolean",
      "description": "Whether budgets and cost centers are tracked"
    },
    "contracts": {
      "type": "boolean",
      "description": "Whether contracts and master agreements are tracked"
    },
    "vendor_onboarding": {
      "type": "boolean",
      "description": "Whether vendor onboarding and compliance is required"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External system integrations"
    },
    "emergency_rules": {
      "type": "boolean",
      "description": "Whether emergency purchasing rules are defined"
    }
  },
  "additionalProperties": false
}
