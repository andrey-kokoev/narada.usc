{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://narada2.dev/schemas/usc/domain-packs/marketplace-context.schema.json",
  "title": "Marketplace Domain Context",
  "type": "object",
  "required": ["domain", "participants", "fulfillment_model"],
  "properties": {
    "domain": { "const": "marketplace" },
    "participants": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Participant types (buyers, sellers, vendors, agents)"
    },
    "fulfillment_model": {
      "type": "string",
      "enum": ["vendor", "platform", "hybrid", "digital", "pickup"],
      "description": "Who is responsible for fulfillment"
    },
    "commission_model": {
      "type": "string",
      "enum": ["percentage", "flat", "tiered", "subscription", "none"],
      "description": "Commission or fee structure"
    },
    "trust_model": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Trust and verification mechanisms"
    },
    "transaction_model": {
      "type": "string",
      "enum": ["platform-payment", "direct", "invoicing", "deposit"],
      "description": "How transactions are handled"
    },
    "messaging": {
      "type": "boolean",
      "description": "Whether buyer-seller messaging is required"
    },
    "catalog_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Types of products/services in catalog"
    },
    "integrations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "External system integrations"
    }
  },
  "additionalProperties": false
}
